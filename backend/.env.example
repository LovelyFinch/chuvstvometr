# Порт сервера
PORT=3000

# API-ключ для авторизации мутирующих запросов
API_KEY=change-me-to-a-secure-key

# Разрешённые CORS origins (через запятую)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Путь к файлу сос��ояния
STATE_FILE=./data/state.json

# Уровень логирования: debug, info, warn, error
LOG_LEVEL=debug

# Окружение: development, production
NODE_ENV=development

# Telegram Bot (опционально — если не задан, бот не запускается)
# Токен от @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
# Список разрешённых Telegram user ID через запятую
TELEGRAM_ALLOWED_USERS=123456789,987654321
